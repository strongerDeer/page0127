{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "src/**"],
      "env": ["OPENAI_API_KEY"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "type-check": {},
    "test": {
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "rebuild": {
      "dependsOn": ["clean"],
      "outputs": [".next/**", "!.next/cache/**", "src/**"]
    }
  }
}

# ============================================
# 로컬 개발 환경변수 템플릿
# 사용법: 이 파일을 .env.local로 복사한 뒤 아래 값들을 실제 값으로 채우세요.
#   cp .env.example .env.local
#
# ⚠️ NEXT_PUBLIC_ 접두사가 붙은 순간 Next.js가 해당 값을
#    클라이언트 번들에 그대로 포함시킵니다. 비밀값에는 절대 붙이지 마세요.
# ============================================

# --- Supabase ---
# Project Settings > API 에서 확인 (공개 — 클라이언트에서 사용)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service Role Key — RLS(행 단위 보안)를 전부 우회하는 관리자 키.
# 서버 전용 코드(admin.ts 등)에서만 사용. 절대 브라우저로 노출되면 안 됨.
SUPABASE_SERVICE_ROLE_KEY=

# --- 외부 API (서버 전용) ---
# OpenAI API — 취향 분석 기능에서 사용
OPENAI_API_KEY=

# 알라딘 도서 검색 API (TTB 키, 알라딘 API 센터에서 발급)
ALADIN_API_KEY=

# --- 사이트 설정 ---
# OAuth 리다이렉트 등에 사용. 비워두면 location.origin으로 대체됨 (선택)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Cron / 배포 ---
# Vercel Cron 요청 인증용 시크릿. 운영/Preview에서는 필수이며, 누락 시 cron API가 실패함
CRON_SECRET=

# --- Sentry ---
# DSN은 브라우저 오류 전송 대상 식별자이므로 공개 가능. 환경별 프로젝트 값을 사용
NEXT_PUBLIC_SENTRY_DSN=

# 소스맵 업로드용 빌드 시크릿. Vercel에만 저장하고 브라우저·Git에 노출 금지
SENTRY_AUTH_TOKEN=

# --- 기타 (선택) ---
# 도서 검색 기본 언어
BOOK_LANG=

# Google Analytics 4 측정 ID (예: G-XXXXXXXXXX). 비워두면 GA 스크립트 자체가 로드되지 않음
NEXT_PUBLIC_GA_ID=
